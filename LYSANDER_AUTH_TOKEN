import os
import requests

def initialize_tiktok_root():
    """
    LYSANDER 3.0: TIKTOK COMMAND ROOT
    Propagates 116x signal via the Developer Gateway
    """
    token = os.getenv("LYSANDER_AUTH_TOKEN")
    # TIKTOK V2 PRODUCTION ENDPOINT
    url = "https://tiktokapis.com"
    
    headers = {
        "Authorization": f"Bearer {token}",
        "Content-Type": "application/json"
    }
    
    # SYSTEM PAYLOAD: QUERYING THE 152k CLUSTER
    body = {
        "max_count": 20,
        "fields": ["id", "title", "view_count", "share_count"]
    }

    try:
        response = requests.post(url, headers=headers, json=body)
        if response.status_code == 200:
            print("[ROOT]: TikTok Bridge Locked. Signal Propagating.")
            return response.json()
        else:
            print(f"[ERROR]: Handshake Rejected: {response.status_code}")
    except Exception as e:
        print(f"[CRITICAL]: Bridge Failure: {e}")

if __name__ == "__main__":
    initialize_tiktok_root()
